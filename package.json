{
  "name": "gcs-designer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "electron:dev": "concurrently \"pnpm dev -- --strictPort\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "pnpm build-only && electron-builder",
    "electron:build:win": "pnpm build-only && electron-builder --win",
    "electron:build:mac": "pnpm build-only && electron-builder --mac",
    "electron:build:all": "pnpm build-only && electron-builder --win --mac"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@meta2d/activity-diagram": "^1.0.0",
    "@meta2d/chart-diagram": "^1.0.7",
    "@meta2d/class-diagram": "^1.0.1",
    "@meta2d/core": "^1.0.42",
    "@meta2d/flow-diagram": "^1.0.0",
    "@meta2d/form-diagram": "^1.0.15",
    "@meta2d/fta-diagram": "^1.0.0",
    "@meta2d/le5le-charts": "^1.0.4",
    "@meta2d/plugin-mind-core": "^1.0.3",
    "@meta2d/sequence-diagram": "^1.0.0",
    "@meta2d/svg": "^1.0.4",
    "axios": "^1.6.8",
    "element-plus": "^2.6.1",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.47.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "vue3-colorpicker": "^2.3.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node20": "^20.1.2",
    "@types/node": "^20.11.28",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/tsconfig": "^0.5.1",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "npm-run-all2": "^6.1.2",
    "prettier": "^3.0.3",
    "typescript": "~5.4.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-icons": "^0.18.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.6",
    "vite-plugin-inspect": "^0.8.3",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue-tsc": "^2.0.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.kami.gcs-editor",
    "productName": "工业组态编辑器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
